                  {}
              fl_wheel_base_link:
                fl_wheel_link:
                  {}
              fr_wheel_base_link:
                fr_wheel_link:
                  {}
              front_bumper_link:
                lights_channel_1_link:
                  {}
              imu_link:
                {}
              rear_bumper_link:
                lights_channel_2_link:
                  {}
              rl_wheel_base_link:
                rl_wheel_link:
                  {}
              rr_wheel_base_link:
                rr_wheel_link:
                  {}
      Update Interval: 0
      Value: true
