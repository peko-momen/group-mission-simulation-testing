        rear_bumper_link:
          Value: true
        rl_wheel_base_link:
          Value: true
        rl_wheel_link:
          Value: true
        rr_wheel_base_link:
          Value: true
        rr_wheel_link:
          Value: true
      Marker Scale: 1
      Name: TF
      Show Arrows: false
      Show Axes: true
      Show Names: true
      Tree:
        odom:
          base_link:
            body_link:
              base_footprint:
                {}
              cover_link:
